# =============================================================================
# AgentLoom — Sample environment file.
# Copy to .env, fill in the values, but DO NOT commit the resulting .env file.
# Real secrets are stored in Azure Key Vault and read via Managed Identity at
# runtime; this file only contains non-secret configuration plus local-dev
# placeholders.
# =============================================================================

# --- Branding (also lives in config/branding.json; env overrides file) -------
PRODUCT_NAME=AgentLoom
PRODUCT_TAGLINE=Weave agents for every customer
PRIMARY_COLOR=#5B5FC7
LOGO_URL=/logo.svg
SUPPORT_EMAIL=support@example.com
PARTNER_NAME=Acme Partner

# --- Azure deployment --------------------------------------------------------
AZURE_RESOURCE_PREFIX=agentloom
AZURE_LOCATION=eastus2
AZURE_ENV_NAME=dev

# --- Backend runtime (filled by Bicep outputs / azd env) ---------------------
COSMOS_ENDPOINT=
COSMOS_DATABASE=agentloom
SEARCH_ENDPOINT=
STORAGE_ACCOUNT=
STORAGE_CONTAINER=knowledge
KEYVAULT_URI=
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-mini

# --- Auth (MVP fallback JWT; replace with External ID JWKS in production) ----
# Secret is sourced from Key Vault at runtime; only set this for local dev.
JWT_SECRET=local-dev-secret-change-me
JWT_ISSUER=agentloom-local
JWT_AUDIENCE=agentloom

# --- Production identity (Entra ID workforce + Entra External ID/CIAM) -------
# AUTH_MODE=dev keeps the HS256 demo flow. AUTH_MODE=production verifies RS256
# tokens via JWKS and DISABLES dev tokens + the demo switcher.
# Provision both tenants with scripts/setup_identity.ps1 (it prints these).
AUTH_MODE=dev
WORKFORCE_TENANT_ID=
WORKFORCE_AUDIENCE=
CIAM_TENANT_ID=
CIAM_SUBDOMAIN=
CIAM_AUDIENCE=
ORG_ID_CLAIM=org_id

# --- CORS --------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
